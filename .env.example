# Vula! Print app environment variables
# Copy this file to .env and set values for your deployment.

# Backend base URL
PRINTER_API_BASE_URL=https://shop.novaconv.co.za

# Required API key used by label + POS endpoints
PRINTER_API_KEY=REPLACE_WITH_BACKEND_PRINTER_API_KEY

# Required for POS queue routing (backend user.id for cashier queue)
PRINTER_USER_ID=1